#!/bin/bash
# Set up Dock layout — re-runs automatically when this file changes

set -euo pipefail

# Ensure Homebrew is on PATH
if [[ -x {{ includeTemplate "brew-prefix" . }}/bin/brew ]]; then
    eval "$({{ includeTemplate "brew-prefix" . }}/bin/brew shellenv)"
fi

if ! command -v dockutil &>/dev/null; then
    echo "dockutil not found, skipping Dock layout."
    exit 0
fi

echo "Setting up Dock layout..."

# Remove all current items
dockutil --remove all --no-restart

# Add apps in order
dockutil --add /Applications/Brave\ Browser.app --no-restart
dockutil --add /Applications/iTerm.app --no-restart
dockutil --add /Applications/Obsidian.app --no-restart
{{ if eq .machine_type "personal" -}}
dockutil --add /Applications/Tidal.app --no-restart
{{ end -}}
dockutil --add /System/Applications/System\ Settings.app --no-restart

# Add Downloads folder as a stack
dockutil --add ~/Downloads --view fan --display stack --sort dateadded

killall Dock 2>/dev/null || true

echo "Dock layout configured."
