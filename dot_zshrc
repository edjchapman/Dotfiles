# Path to your oh-my-zsh installation.
export ZSH=~/.oh-my-zsh

export DEFAULT_USER=$USER

export ZSH_THEME="agnoster"

# Command auto-correction.
export ENABLE_CORRECTION="true"

export HIST_STAMPS="yyyy-mm-dd"

# History configuration
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_REDUCE_BLANKS
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY
setopt HIST_IGNORE_SPACE

export plugins=(
    git
    python
    virtualenv
    pip
    brew
)

source $ZSH/oh-my-zsh.sh

# Lazy-load thefuck (saves ~200ms on shell startup)
fuck() { unfunction fuck; eval $(thefuck --alias); fuck "$@"; }

# Set CLICOLOR if you want Ansi Colors in iTerm2
export CLICOLOR=1

# Set colors to match iTerm2 Terminal Colors
export TERM=xterm-256color

# PATH
export PATH="/usr/local/sbin:$HOME/bin:/usr/local/bin:$PATH"
export PATH="$PATH:$HOME/.local/bin"

# GNU tools — override BSD defaults with GNU versions
if [[ -d /opt/homebrew/opt/coreutils ]]; then
    for gnubin in coreutils findutils gnu-sed gawk diffutils; do
        [[ -d "/opt/homebrew/opt/$gnubin/libexec/gnubin" ]] && \
            export PATH="/opt/homebrew/opt/$gnubin/libexec/gnubin:$PATH"
    done
fi

# Completions (homebrew + custom)
fpath=(~/.zfunc $fpath)
if type brew &>/dev/null; then
    FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
fi
autoload -Uz compinit
compinit

# fnm (Fast Node Manager) — auto-switch Node version on cd
if command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd --shell zsh)"
fi

# fzf key bindings and completion
if command -v fzf &>/dev/null; then
    source <(fzf --zsh)
fi

# iTerm2 shell integration (installed on first launch of iTerm2)
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh" || true

# MySQL — paths for mysql@8.4 (only if installed)
if [[ -d /opt/homebrew/opt/mysql@8.4 ]]; then
    export PATH="/opt/homebrew/opt/mysql@8.4/bin:$PATH"
    export LDFLAGS="-L/opt/homebrew/opt/mysql@8.4/lib"
    export CPPFLAGS="-I/opt/homebrew/opt/mysql@8.4/include"
fi

# Machine-specific secrets and credentials (AWS, GitHub, Jira, etc.)
# Managed by chezmoi (encrypted_dot_zshrc.local.age)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# Windsurf (only if installed)
[[ -d "$HOME/.codeium/windsurf/bin" ]] && export PATH="$HOME/.codeium/windsurf/bin:$PATH"

# Sync with origin and safely clean up stale branches
hub-sync-clean() {
  echo "Syncing with origin..."
  hub sync
  git fetch --prune

  echo "Checking for branches whose remote no longer exists..."
  local -a gone_branches
  gone_branches=("${(@f)$(git branch -vv | awk '/: gone]/{print $1}')}")

  if [[ ${#gone_branches[@]} -eq 0 || -z "${gone_branches[1]}" ]]; then
    echo "No stale branches to remove."
    return
  fi

  local merged
  merged=$(git branch --merged main)

  local -a merged_gone unmerged_gone
  for branch in "${gone_branches[@]}"; do
    if echo "$merged" | grep -qE "^[* ] ${branch}$"; then
      merged_gone+=("$branch")
    else
      unmerged_gone+=("$branch")
    fi
  done

  if [[ ${#merged_gone[@]} -gt 0 ]]; then
    echo "Merged branches (safe to delete):"
    for branch in "${merged_gone[@]}"; do
      echo "  - $branch"
    done
    echo
    read "reply?Delete these ${#merged_gone[@]} merged branches? [y/N] "
    if [[ $reply =~ ^[Yy]$ ]]; then
      for branch in "${merged_gone[@]}"; do
        git branch -d "$branch"
      done
      echo "Merged branches deleted."
    fi
  fi

  if [[ ${#unmerged_gone[@]} -gt 0 ]]; then
    echo
    echo "WARNING: Unmerged branches (remote deleted, local changes may be lost):"
    for branch in "${unmerged_gone[@]}"; do
      echo "  - $branch"
    done
    echo
    read "reply?Force delete these ${#unmerged_gone[@]} unmerged branches? [y/N] "
    if [[ $reply =~ ^[Yy]$ ]]; then
      for branch in "${unmerged_gone[@]}"; do
        git branch -D "$branch"
      done
      echo "Unmerged branches force-deleted."
    else
      echo "Unmerged branches kept."
    fi
  fi

  echo "Clean-up complete."
}

# CLAUDE
export DISABLE_AUTOUPDATER=1
export ENABLE_TOOL_SEARCH=auto:5

# Suppress Homebrew informational hints while keeping automatic updates enabled
export HOMEBREW_NO_ENV_HINTS=1

# Homebrew daily maintenance: upgrade, sanity-check, cleanup
brewup() {
  emulate -L zsh
  setopt pipefail

  print -P "\n%F{cyan}==> brew upgrade%f"
  if ! command brew upgrade; then
    print -P "%F{red}brew upgrade failed%f"
    return 1
  fi

  print -P "\n%F{cyan}==> brew doctor%f"
  if ! command brew doctor; then
    print -P "%F{yellow}brew doctor reported issues (non-fatal)%f"
  fi

  print -P "\n%F{cyan}==> brew cleanup%f"
  command brew cleanup

  print -P "\n%F{green}Done.%f\n"
}

# Auto-run brewup once per day on first shell. Output is appended to
# ~/.cache/brewup.log (last ~2000 lines kept); `brewlog` tails it.
# A directory-based lock prevents concurrent runs when multiple shells
# open in quick succession. Stale locks (>1h) are cleared on next entry.
BREWUP_STAMP="$HOME/.cache/brewup.last"
BREWUP_LOG="$HOME/.cache/brewup.log"
BREWUP_LOCK="$HOME/.cache/brewup.lock"
mkdir -p "$HOME/.cache"

if [[ -d "$BREWUP_LOCK" ]]; then
  _brewup_lock_mtime=$(stat -f %m "$BREWUP_LOCK" 2>/dev/null || echo 0)
  (( $(date +%s) - _brewup_lock_mtime > 3600 )) && rmdir "$BREWUP_LOCK" 2>/dev/null
  unset _brewup_lock_mtime
fi

if [[ ! -f "$BREWUP_STAMP" || "$(date +%F)" != "$(cat "$BREWUP_STAMP" 2>/dev/null)" ]]; then
  (
    if mkdir "$BREWUP_LOCK" 2>/dev/null; then
      trap 'rmdir "$BREWUP_LOCK" 2>/dev/null' EXIT INT TERM HUP
      {
        echo "=== brewup $(date '+%Y-%m-%d %H:%M:%S') ==="
        if brewup; then
          date +%F >| "$BREWUP_STAMP"
        fi
      } >>"$BREWUP_LOG" 2>&1
      tail -n 2000 "$BREWUP_LOG" >"$BREWUP_LOG.tmp" 2>/dev/null && mv "$BREWUP_LOG.tmp" "$BREWUP_LOG"
    fi
  ) &!
fi

# Short aliases for the management surface (see CLAUDE.md / README).
alias mac='chezmoi-fix'
alias brewlog='tail -F ~/.cache/brewup.log'

# chezmoi drift banner — surfaces $HOME and Brewfile drift on shell start.
# Cached state is read synchronously (cheap). A TTL-bounded refresh is kicked
# off in the background — it only re-runs the full check when the cache is
# older than $CHEZMOI_DRIFT_TTL (default 4h), otherwise it's a no-op.
# CHEZMOI_DRIFT_QUIET=1 silences the banner only; the cache still refreshes
# and the daily launchd notification still fires.
if [[ -z "${CHEZMOI_DRIFT_QUIET:-}" ]] && command -v chezmoi-drift-check &>/dev/null; then
  _drift_state="$HOME/.cache/chezmoi-drift/state"
  _showed_banner=0
  _cache_age=-1
  if [[ -f "$_drift_state" ]]; then
    # shellcheck disable=SC1090
    source "$_drift_state" 2>/dev/null
    _drift_total=$(( ${HOME_DRIFT:-0} + ${BREW_MISSING:-0} + ${BREW_EXTRA:-0} + ${DEFAULTS_DRIFT:-0} + ${SECURITY_DRIFT:-0} ))
    # Cache age — used both to gate the background refresh below (avoid one
    # fork per new shell/tmux pane when state is still fresh) and to annotate
    # the banner when the snapshot is materially stale.
    _age_suffix=
    if [[ "${CHECKED_AT:-0}" =~ ^[0-9]+$ ]] && (( CHECKED_AT > 0 )); then
      _cache_age=$(( $(date +%s) - CHECKED_AT ))
      if (( _cache_age >= 3600 )); then
        _age_suffix=" (as of $(( _cache_age / 3600 ))h ago)"
      fi
    fi
    if (( _drift_total > 0 )); then
      _drift_word=things; (( _drift_total == 1 )) && _drift_word=thing
      print -P "%F{yellow}chezmoi: ${_drift_total} ${_drift_word} need attention${_age_suffix} — run 'mac'%f"
      unset _drift_word
      _showed_banner=1
    elif [[ "${HAD_ERROR:-0}" == "1" ]]; then
      print -P "%F{yellow}chezmoi: drift check encountered an error${_age_suffix} — run 'mac'%f"
      _showed_banner=1
    fi
    unset HOME_DRIFT BREW_MISSING BREW_EXTRA DEFAULTS_DRIFT SECURITY_DRIFT HAD_ERROR CHECKED_AT summary _drift_total _age_suffix
  fi
  unset _drift_state
  # Background refresh — only spawn when the cache is missing or older than
  # CHEZMOI_DRIFT_TTL (default 4h). The script itself would no-op inside the
  # TTL window, but skipping the fork keeps a fresh tmux session from
  # spawning N chezmoi-drift-check processes for no work.
  if (( _cache_age < 0 || _cache_age >= ${CHEZMOI_DRIFT_TTL:-14400} )); then
    (chezmoi-drift-check --brief --quiet) &>/dev/null &!
  fi
  unset _cache_age

  # brew-inbox banner — surfaces pending events recorded by the brew()/mas()
  # wrappers. The journal is ephemeral (~/.cache); count flips red at >= 10 so
  # users notice before it becomes a chore.
  _inbox="${XDG_CACHE_HOME:-$HOME/.cache}/chezmoi-brew-inbox/journal.ndjson"
  if [[ -s $_inbox ]]; then
    _n=$(wc -l <"$_inbox" | tr -d ' ')
    _color=yellow
    (( _n >= 10 )) && _color=red
    _ev_word=events; (( _n == 1 )) && _ev_word=event
    print -P "%F{$_color}chezmoi: $_n brew ${_ev_word} pending — run 'mac'%f"
    unset _n _color _ev_word
    _showed_banner=1
  fi
  unset _inbox

  # Quiet shortcuts tip when nothing else fired. Avoids competing with a
  # real banner; uses dim grey (%F{8}) so it never dominates the prompt.
  if (( _showed_banner == 0 )); then
    print -P "%F{8}tip: 'mac' for chezmoi state · 'brewlog' for today's brew output%f"
  fi
  unset _showed_banner
fi

# brew/mas wrappers — record each mutating invocation to the inbox journal and
# kick off an async drift refresh. The recorder is silent on failure so it can
# never break a working brew/mas command.
brew() {
  command brew "$@"
  local rc=$? subcmd="${1:-}"
  case "$subcmd" in
    install|uninstall|reinstall|tap|untap)
      command -v chezmoi-brew-record &>/dev/null && \
        chezmoi-brew-record --rc "$rc" -- "$@" &>/dev/null &!
      command -v chezmoi-drift-check &>/dev/null && \
        (chezmoi-drift-check --full --quiet) &>/dev/null &!
      ;;
  esac
  return $rc
}

mas() {
  command mas "$@"
  local rc=$? subcmd="${1:-}"
  case "$subcmd" in
    install|uninstall|purchase)
      command -v chezmoi-brew-record &>/dev/null && \
        chezmoi-brew-record --rc "$rc" --tool mas -- "$@" &>/dev/null &!
      command -v chezmoi-drift-check &>/dev/null && \
        (chezmoi-drift-check --full --quiet) &>/dev/null &!
      ;;
  esac
  return $rc
}
