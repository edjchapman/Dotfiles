[user]
	name = Ed Chapman
	email = edchapman88@gmail.com
{{- if .gpg_signing_key }}
	signingkey = {{ .gpg_signing_key }}
{{- end }}
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[init]
	defaultBranch = main
[core]
	ignorecase = false
	autocrlf = input
	hooksPath = ~/.config/git/hooks
{{- if .gpg_signing_key }}
[commit]
	gpgsign = true
[gpg]
	program = {{ lookPath "gpg" }}
{{- end }}
[alias]
	# Squash-merge-aware sync. After a squash-merge the original branch
	# isn't an ancestor of main, so `--merged` doesn't catch it; the
	# `[gone]`-upstream prune (step 2) handles those. The awk filter
	# skips the currently-checked-out branch ($1 == "*") so the pipeline
	# can't try to delete the current HEAD.
	sync = "!f() { \
		git fetch --all --prune && \
		git branch -vv | awk '/: gone]/ && $1 != \"*\" {print $1}' | xargs -r -n1 git branch -D; \
		git pull --ff-only --autostash && \
		git branch --merged | grep -vE '^\\*|^\\s*(main|master)$' | xargs -r -n1 git branch -d; \
	}; f"
[credential "https://github.com"]
	helper =
	helper = !{{ if eq .chezmoi.arch "arm64" }}/opt/homebrew/bin/gh{{ else }}/usr/local/bin/gh{{ end }} auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !{{ if eq .chezmoi.arch "arm64" }}/opt/homebrew/bin/gh{{ else }}/usr/local/bin/gh{{ end }} auth git-credential
