#!/bin/bash
# Install Homebrew packages from Brewfile
# chezmoi run_onchange: re-runs whenever Brewfile content changes
# Brewfile hash: {{ include "Brewfile.tmpl" | sha256sum }}

set -euo pipefail

# Ensure Homebrew is on PATH (needed on fresh machines where shell profile hasn't loaded)
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

if command -v brew &>/dev/null; then
    echo "Running brew bundle..."
    rendered="$(mktemp -t Brewfile.rendered.XXXXXX)"
    trap 'rm -f "$rendered"' EXIT
    chezmoi execute-template < "{{ .chezmoi.sourceDir }}/Brewfile.tmpl" >"$rendered"
    brew bundle --file="$rendered"
else
    echo "ERROR: Homebrew not found. Run setup step 01 first."
    exit 1
fi
