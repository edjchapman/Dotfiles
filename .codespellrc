[codespell]
# Skip generated/binary outputs and the VHS demo source (terminal escapes look
# like typos to codespell).
skip = .git,site,node_modules,*.lock,assets/demo/*.tape,*.svg,*.png

# Project-specific terms and proper nouns codespell would otherwise flag.
ignore-words-list = chezmoi,brewup,vhs,lulu,dockutil,mas,ed,nd,fo,ot,thru,te,nin,mke,ans,iam,ist,unx,iterm,homestate,accreting,accrete,acrete

# Add new acceptable words by extending the list above.

quiet-level = 2
