#!/usr/bin/env bash
# chezmoi-drift-check — detect drift between $HOME and chezmoi source state.
# Read-only w.r.t. $HOME. Cached. Safe to call from shell startup, launchd, or interactively.
#
# Drift sources covered:
#   - $HOME files chezmoi manages (via `chezmoi status --exclude=externals`)
#   - Brewfile.tmpl: missing entries (`brew bundle check`),
#     extras (`brew bundle cleanup` dry-run)
#
# State file (sourced by the dot_zshrc banner block) is written atomically via
# tmp+mv so concurrent writers (launchd, brew wrapper, shell startup refresh)
# never leave a partially-written file for the synchronous reader.

set -uo pipefail

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/chezmoi-drift"
STATE_FILE="$CACHE_DIR/state"
TTL="${CHEZMOI_DRIFT_TTL:-14400}"
MODE=brief
NOTIFY=0
ALERT=0
QUIET=0

usage() {
    cat <<'EOF'
chezmoi-drift-check [--brief|--full] [--notify|--alert] [--quiet]

  --brief   (default) Use cached state if newer than $CHEZMOI_DRIFT_TTL (default 4h);
            otherwise re-run all checks.
  --full    Always re-run all checks, ignoring the cache.
  --notify  Post a macOS Notification Center alert if drift is detected (fire-and-forget).
  --alert   Post a clickable AppleScript dialog with a "Fix now" button that launches
            chezmoi-fix in iTerm. Auto-dismisses after 90 seconds. Implies --notify is not used.
  --quiet   Suppress stdout; exit code only.

Exit codes: 0 clean, 1 drift, 2 error (a check could not be run).
State cache: $XDG_CACHE_HOME/chezmoi-drift/state (or ~/.cache/...).
EOF
}

for arg in "$@"; do
    case "$arg" in
        --brief) MODE=brief ;;
        --full) MODE=full ;;
        --notify) NOTIFY=1 ;;
        --alert) ALERT=1 ;;
        --quiet) QUIET=1 ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            echo "chezmoi-drift-check: unknown arg: $arg" >&2
            usage >&2
            exit 2
            ;;
    esac
done

emit() { [[ $QUIET -eq 0 ]] && printf '%s\n' "$*"; }

if ! command -v chezmoi >/dev/null 2>&1; then
    emit "chezmoi-drift-check: chezmoi not installed; skipping"
    exit 0
fi

if ! mkdir -p "$CACHE_DIR"; then
    emit "chezmoi-drift-check: cannot create $CACHE_DIR" >&2
    exit 2
fi

cache_fresh() {
    [[ -f "$STATE_FILE" ]] || return 1
    local now mtime
    now=$(date +%s)
    mtime=$(stat -f %m "$STATE_FILE" 2>/dev/null || stat -c %Y "$STATE_FILE" 2>/dev/null)
    # Force mtime to a non-negative integer. Without this, any stat oddity
    # (empty output, locale-decorated text, partial read during atomic rotate)
    # leaks into the arithmetic context below where bash's name-resolution can
    # then trigger a confusing `unbound variable` error under `set -u`.
    [[ $mtime =~ ^[0-9]+$ ]] || mtime=0
    ((now - mtime < TTL))
}

# Brief mode: fast path, return cached state if fresh.
# Defaults shield us from a partially-written or schema-drifted state file.
if [[ $MODE == "brief" ]] && cache_fresh; then
    HOME_DRIFT=
    BREW_MISSING=
    BREW_EXTRA=
    DEFAULTS_DRIFT=0
    SECURITY_DRIFT=0
    HAD_ERROR=0
    summary=
    # shellcheck disable=SC1090
    . "$STATE_FILE" 2>/dev/null || true
    # Validate every required field parsed as a non-negative integer.
    # If any is missing/non-numeric, the cache file is partial or schema-drifted —
    # fall through to the full check rather than silently report stale counts.
    # DEFAULTS_DRIFT / SECURITY_DRIFT are forward-compatible: if absent in an
    # older cache file, they default to 0.
    if [[ $HOME_DRIFT =~ ^[0-9]+$ &&
        $BREW_MISSING =~ ^[0-9]+$ &&
        $BREW_EXTRA =~ ^[0-9]+$ &&
        ${DEFAULTS_DRIFT:-0} =~ ^[0-9]+$ &&
        ${SECURITY_DRIFT:-0} =~ ^[0-9]+$ &&
        -n $summary ]]; then
        emit "$summary"
        [[ ${HAD_ERROR:-0} -gt 0 ]] && exit 2
        [[ $((HOME_DRIFT + BREW_MISSING + BREW_EXTRA + ${DEFAULTS_DRIFT:-0} + ${SECURITY_DRIFT:-0})) -gt 0 ]] && exit 1
        exit 0
    fi
    # Cache invalid; fall through to full check.
fi

# --- Full check ---
HOME_DRIFT=0
BREW_MISSING=0
BREW_EXTRA=0
DEFAULTS_DRIFT=0
SECURITY_DRIFT=0
HAD_ERROR=0
err_parts=""

# Home drift via `chezmoi status`. Capture failure explicitly — without this,
# any chezmoi error (config syntax, missing age key, deprecated flag) silently
# yields HOME_DRIFT=0, which is the textbook silent-failure pattern this whole
# feature is meant to prevent.
if status_out=$(chezmoi status --exclude=externals 2>&1); then
    HOME_DRIFT=$(printf '%s\n' "$status_out" | sed '/^$/d' | wc -l | tr -d ' ')
    HOME_DRIFT=${HOME_DRIFT:-0}
else
    HAD_ERROR=1
    err_parts="${err_parts:+$err_parts; }chezmoi status failed"
fi

if command -v brew >/dev/null 2>&1; then
    rendered=$(mktemp -t brewfile-rendered.XXXXXX)
    # shellcheck disable=SC2064
    trap "rm -f '$rendered'" EXIT INT TERM HUP
    if ! chezmoi execute-template <"$(chezmoi source-path)/Brewfile.tmpl" >"$rendered" 2>/dev/null; then
        HAD_ERROR=1
        err_parts="${err_parts:+$err_parts; }Brewfile.tmpl render failed"
    else
        # Missing: brew bundle check exits non-zero when entries are missing OR when it
        # itself errors. Distinguish by inspecting verbose output.
        verbose_out=$(brew bundle check --no-upgrade --verbose --file="$rendered" 2>&1)
        verbose_rc=$?
        BREW_MISSING=$(printf '%s\n' "$verbose_out" | grep -cE '(needs to be installed|not installed)' || true)
        if [[ $verbose_rc -ne 0 && $BREW_MISSING -eq 0 ]]; then
            HAD_ERROR=1
            err_parts="${err_parts:+$err_parts; }brew bundle check failed"
        fi
        # Extras: cleanup dry-run. Same pattern — non-zero exit with no matched lines means errored.
        cleanup_out=$(brew bundle cleanup --file="$rendered" 2>&1)
        cleanup_rc=$?
        BREW_EXTRA=$(printf '%s\n' "$cleanup_out" | grep -cE '^Would (uninstall|untap|remove)' || true)
        if [[ $cleanup_rc -ne 0 && $BREW_EXTRA -eq 0 ]]; then
            HAD_ERROR=1
            err_parts="${err_parts:+$err_parts; }brew bundle cleanup failed"
        fi
    fi
fi

# macOS defaults drift — counts settings that diverged from the source script.
# The audit is best-effort; if it fails entirely, record the error but don't
# poison the other counts. Skipped silently when the audit tool isn't on PATH
# (e.g., during early bootstrap before chezmoi apply has run).
if command -v chezmoi-defaults-audit >/dev/null 2>&1; then
    # The audit exits 1 when drift is detected — that's the expected outcome,
    # not an error. Only treat empty/garbled output as a real error.
    audit_out=$(chezmoi-defaults-audit --quiet 2>/dev/null) || true
    if [[ -n $audit_out ]]; then
        DEFAULTS_DRIFT=$(printf '%s' "$audit_out" | awk -F'\t' '{print $2}')
        [[ $DEFAULTS_DRIFT =~ ^[0-9]+$ ]] || DEFAULTS_DRIFT=0
    else
        HAD_ERROR=1
        err_parts="${err_parts:+$err_parts; }defaults audit failed"
    fi
fi

# Security baseline drift — counts failing security checks.
if command -v chezmoi-security-audit >/dev/null 2>&1; then
    sec_out=$(chezmoi-security-audit --quiet 2>/dev/null) || true
    if [[ -n $sec_out ]]; then
        SECURITY_DRIFT=$(printf '%s' "$sec_out" | awk -F'\t' '{print $2}')
        [[ $SECURITY_DRIFT =~ ^[0-9]+$ ]] || SECURITY_DRIFT=0
    else
        HAD_ERROR=1
        err_parts="${err_parts:+$err_parts; }security audit failed"
    fi
fi

parts=""
[[ $HOME_DRIFT -gt 0 ]] && parts="${parts:+$parts, }home: $HOME_DRIFT"
[[ $BREW_MISSING -gt 0 ]] && parts="${parts:+$parts, }brew-missing: $BREW_MISSING"
[[ $BREW_EXTRA -gt 0 ]] && parts="${parts:+$parts, }brew-extra: $BREW_EXTRA"
[[ $DEFAULTS_DRIFT -gt 0 ]] && parts="${parts:+$parts, }defaults: $DEFAULTS_DRIFT"
[[ $SECURITY_DRIFT -gt 0 ]] && parts="${parts:+$parts, }security: $SECURITY_DRIFT"

if [[ $HAD_ERROR -eq 1 ]]; then
    if [[ -n $parts ]]; then
        summary="drift: $parts · ERROR: $err_parts (counts may be incomplete)"
    else
        summary="drift: ERROR: $err_parts"
    fi
elif [[ -z $parts ]]; then
    summary="drift: clean"
else
    summary="drift: $parts"
fi

# Atomic state-file write: tmp+mv so a concurrent reader never sees a partial file.
state_tmp="$STATE_FILE.tmp.$$"
if {
    printf 'HOME_DRIFT=%s\n' "$HOME_DRIFT"
    printf 'BREW_MISSING=%s\n' "$BREW_MISSING"
    printf 'BREW_EXTRA=%s\n' "$BREW_EXTRA"
    printf 'DEFAULTS_DRIFT=%s\n' "$DEFAULTS_DRIFT"
    printf 'SECURITY_DRIFT=%s\n' "$SECURITY_DRIFT"
    printf 'HAD_ERROR=%s\n' "$HAD_ERROR"
    printf 'CHECKED_AT=%s\n' "$(date +%s)"
    printf 'summary=%q\n' "$summary"
} >"$state_tmp"; then
    mv -f "$state_tmp" "$STATE_FILE" || rm -f "$state_tmp"
else
    rm -f "$state_tmp"
fi

emit "$summary"

total=$((HOME_DRIFT + BREW_MISSING + BREW_EXTRA + DEFAULTS_DRIFT + SECURITY_DRIFT))
should_notify=0
[[ $NOTIFY -eq 1 || $ALERT -eq 1 ]] && [[ $total -gt 0 || $HAD_ERROR -eq 1 ]] && should_notify=1

if [[ $should_notify -eq 1 ]]; then
    # Escape backslashes and double-quotes for AppleScript string interpolation.
    notify_body=${summary//\\/\\\\}
    notify_body=${notify_body//\"/\\\"}

    if [[ $ALERT -eq 1 ]]; then
        # Clickable dialog with a "Fix now" button. Auto-dismisses after 90 seconds.
        # The result includes "button returned:Fix now" when chosen; we launch iTerm
        # and run chezmoi-fix in a fresh window. AppleScript escaping is the same
        # as for display notification.
        result=$(
            osascript <<APPLESCRIPT 2>/dev/null
try
    tell application "System Events"
        set theResp to display dialog "$notify_body" with title "chezmoi drift" buttons {"Dismiss", "Fix now"} default button "Fix now" giving up after 90 with icon caution
    end tell
    return button returned of theResp
on error
    return ""
end try
APPLESCRIPT
        )
        if [[ $result == "Fix now" ]]; then
            # Open iTerm and run chezmoi-fix in a new window. Fall back to opening
            # Terminal.app if iTerm isn't installed.
            if osascript -e 'tell application "iTerm" to activate' >/dev/null 2>&1; then
                osascript <<'APPLESCRIPT' >/dev/null 2>&1 || true
tell application "iTerm"
    activate
    set newWindow to (create window with default profile)
    tell current session of newWindow to write text "chezmoi-fix"
end tell
APPLESCRIPT
            else
                osascript <<'APPLESCRIPT' >/dev/null 2>&1 || true
tell application "Terminal"
    activate
    do script "chezmoi-fix"
end tell
APPLESCRIPT
            fi
        fi
    else
        # Non-interactive notification (existing behaviour).
        osascript -e "display notification \"$notify_body\" with title \"chezmoi drift\"" >/dev/null 2>&1 || true
    fi
fi

if [[ $HAD_ERROR -eq 1 ]]; then
    exit 2
fi
[[ $total -gt 0 ]] && exit 1
exit 0
