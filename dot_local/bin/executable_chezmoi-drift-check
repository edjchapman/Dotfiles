#!/usr/bin/env bash
# chezmoi-drift-check — detect drift between $HOME and chezmoi source state.
# Read-only. Cached. Safe to call from shell startup, launchd, or interactively.
#
# Drift sources covered:
#   - $HOME files chezmoi manages (via `chezmoi status`)
#   - Brewfile.tmpl (missing entries via `brew bundle check`,
#     extras via `brew bundle cleanup` dry-run)

set -uo pipefail

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/chezmoi-drift"
STATE_FILE="$CACHE_DIR/state"
TTL="${CHEZMOI_DRIFT_TTL:-14400}"
MODE=brief
NOTIFY=0
QUIET=0

usage() {
    cat <<'EOF'
chezmoi-drift-check [--brief|--full] [--notify] [--quiet]

  --brief   Use cached state if newer than $CHEZMOI_DRIFT_TTL (default 4h).
  --full    Always re-run all checks. (default when run interactively)
  --notify  Post a macOS notification if drift is detected.
  --quiet   Suppress stdout; exit code only.

Exit codes: 0 clean, 1 drift, 2 error.
State cache: $XDG_CACHE_HOME/chezmoi-drift/state (or ~/.cache/...).
EOF
}

for arg in "$@"; do
    case "$arg" in
        --brief) MODE=brief ;;
        --full) MODE=full ;;
        --notify) NOTIFY=1 ;;
        --quiet) QUIET=1 ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            echo "chezmoi-drift-check: unknown arg: $arg" >&2
            usage >&2
            exit 2
            ;;
    esac
done

emit() { [[ $QUIET -eq 0 ]] && printf '%s\n' "$*"; }

if ! command -v chezmoi >/dev/null 2>&1; then
    emit "chezmoi-drift-check: chezmoi not installed; skipping"
    exit 0
fi

mkdir -p "$CACHE_DIR"

cache_fresh() {
    [[ -f "$STATE_FILE" ]] || return 1
    local now mtime age
    now=$(date +%s)
    mtime=$(stat -f %m "$STATE_FILE" 2>/dev/null || stat -c %Y "$STATE_FILE" 2>/dev/null || echo 0)
    age=$((now - mtime))
    [[ $age -lt $TTL ]]
}

if [[ $MODE == "brief" ]] && cache_fresh; then
    HOME_DRIFT=0
    BREW_MISSING=0
    BREW_EXTRA=0
    summary="drift: clean"
    # shellcheck disable=SC1090
    . "$STATE_FILE"
    emit "$summary"
    [[ $((HOME_DRIFT + BREW_MISSING + BREW_EXTRA)) -gt 0 ]] && exit 1
    exit 0
fi

# --- Full check ---
HOME_DRIFT=$(chezmoi status --exclude=externals 2>/dev/null | sed '/^$/d' | wc -l | tr -d ' ')
HOME_DRIFT=${HOME_DRIFT:-0}

BREW_MISSING=0
BREW_EXTRA=0
if command -v brew >/dev/null 2>&1; then
    rendered=$(mktemp -t brewfile-rendered.XXXXXX)
    trap 'rm -f "$rendered"' EXIT
    if chezmoi execute-template <"$(chezmoi source-path)/Brewfile.tmpl" >"$rendered" 2>/dev/null; then
        if ! brew bundle check --no-upgrade --file="$rendered" >/dev/null 2>&1; then
            BREW_MISSING=$(brew bundle check --no-upgrade --verbose --file="$rendered" 2>/dev/null \
                | grep -cE '(needs to be installed|not installed)' || true)
        fi
        BREW_EXTRA=$(brew bundle cleanup --file="$rendered" 2>/dev/null \
            | grep -cE '^Would (uninstall|untap|remove)' || true)
    fi
fi

parts=""
[[ $HOME_DRIFT -gt 0 ]] && parts="${parts:+$parts, }home: $HOME_DRIFT"
[[ $BREW_MISSING -gt 0 ]] && parts="${parts:+$parts, }brew-missing: $BREW_MISSING"
[[ $BREW_EXTRA -gt 0 ]] && parts="${parts:+$parts, }brew-extra: $BREW_EXTRA"

if [[ -z $parts ]]; then
    summary="drift: clean"
else
    summary="drift: $parts · run 'chezmoi-drift-check --full' (see docs/runbooks/recover-from-drift.md)"
fi

{
    printf 'HOME_DRIFT=%s\n' "$HOME_DRIFT"
    printf 'BREW_MISSING=%s\n' "$BREW_MISSING"
    printf 'BREW_EXTRA=%s\n' "$BREW_EXTRA"
    printf 'CHECKED_AT=%s\n' "$(date +%s)"
    printf 'summary=%q\n' "$summary"
} >"$STATE_FILE"

emit "$summary"

total=$((HOME_DRIFT + BREW_MISSING + BREW_EXTRA))
if [[ $NOTIFY -eq 1 && $total -gt 0 ]]; then
    osascript -e "display notification \"$summary\" with title \"chezmoi drift\"" >/dev/null 2>&1 || true
fi

[[ $total -gt 0 ]] && exit 1
exit 0
